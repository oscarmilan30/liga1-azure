{
  "name": "sch_ml_liga1",
  "email_notifications": {
    "on_success": [
      "{USER}"
    ],
    "on_failure": [
      "{USER}"
    ],
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "notification_settings": {
    "no_alert_for_skipped_runs": false,
    "no_alert_for_canceled_runs": false
  },
  "timeout_seconds": 14400,
  "max_concurrent_runs": 1,
  "git_source": {
    "git_url": "https://github.com/oscarmilan30/liga1-azure",
    "git_provider": "gitHub",
    "git_branch": "main"
  },
  "tasks": [
    {
      "task_key": "nb_ft_score_ml",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "proceso/frm_ml/notebooks/ft_score_ml/nb_ft_score_ml",
        "base_parameters": {
          "prm_pipelineid": "45"
        },
        "source": "GIT"
      },
      "existing_cluster_id": "{CLUSTER_ID}",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "disabled": false,
      "libraries": [
        {
          "whl": "{WHEEL_PATH}"
        }
      ]
    }
  ],
  "tags": {
    "Env": "Prod",
    "Proyecto": "Liga1",
    "Unidad": "ML"
  },
  "queue": {
    "enabled": true
  },
  "performance_target": "PERFORMANCE_OPTIMIZED",
  "run_as": {
    "user_name": "{USER}"
  }
}