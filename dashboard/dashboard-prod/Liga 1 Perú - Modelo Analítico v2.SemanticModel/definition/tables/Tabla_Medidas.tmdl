	/// Porcentaje de tiros que no fueron a portería (1 - Precision Disparo)
	measure 'Tiros Fuera Pct' =
			
			1 - [Precision Disparo]
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: pa001001-0001-0001-0001-000000000008

		annotation PBI_FormatHint = {"isGeneralNumber":false}

	/// Porcentaje de disparos a portería que terminaron en gol
	measure 'Pct Conversion Porteria' =
			
			DIVIDE(
			    SUM(ft_partidos_equipo[goles_favor]),
			    SUM(ft_partidos_equipo[disparos_puerta]),
			    0
			)
		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: pa001001-0001-0001-0001-000000000009

		annotation PBI_FormatHint = {"isGeneralNumber":false}

	/// Complemento de conversión a portería (disparos_puerta sin gol)
	measure 'Pct No Conversion Porteria' =
			
