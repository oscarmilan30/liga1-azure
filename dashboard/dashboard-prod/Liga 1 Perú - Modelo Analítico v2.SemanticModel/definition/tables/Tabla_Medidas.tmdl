			    "Disparos a Portería", SUM(ft_partidos_equipo[disparos_puerta]),
			    "Posesión %", AVERAGE(ft_partidos_equipo[posesion_pct]),
			    "Saques de Esquina", SUM(ft_partidos_equipo[saques_esquina]),
