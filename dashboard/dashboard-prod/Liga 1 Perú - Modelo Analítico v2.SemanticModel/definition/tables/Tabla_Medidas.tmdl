			        CALCULATE(
			            MAX(ft_partidos_equipo[tarjetas_rojas]),
			            FILTER(ALL(ft_partidos_equipo), ft_partidos_equipo[id_partido] = pid && ft_partidos_equipo[rol_equipo] = "VISITANTE")
			        )
			)
		lineageTag: 6fbbc5ec-afc0-4741-9018-d6c6971765d1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Partido Default Id' =
			
			VAR t =
			    TOPN(
			        1,
			        FILTER(
			            ALLSELECTED(ft_partidos_equipo),
			            ft_partidos_equipo[rol_equipo] = "LOCAL"
			                && ft_partidos_equipo[partido_sin_info] = 0
			        ),
			        ft_partidos_equipo[fecha_partido], ASC,
			        ft_partidos_equipo[id_partido], ASC
			    )
			RETURN
			    MAXX(t, ft_partidos_equipo[id_partido])
		lineageTag: ac30076c-2edc-4bd8-a7ab-493b6aeb7cb2

	measure 'Partido Seleccionado Id' =
			
			COALESCE(
			    SELECTEDVALUE(ft_partidos_equipo[id_partido]),
			    [Partido Default Id]
			)
		lineageTag: 1e8bbcc1-cc67-44ac-961d-4e3e426c57eb

	measure 'XI Ideal Campo' =
			
			VAR Tabla =
			    SELECTCOLUMNS(
			        jugadores_slots,
			        "slot",          jugadores_slots[slot],
			        "jugador",       jugadores_slots[jugador],
			        "foto_url",      jugadores_slots[foto_url],
			        "posicion_xi",   jugadores_slots[posicion_xi],
			        "x_coord",       jugadores_slots[x_coord],
			        "y_coord",       jugadores_slots[y_coord],
			        "score",         jugadores_slots[score],
			        "goles",         jugadores_slots[goles],
			        "asistencias",   jugadores_slots[asistencias],
			        "minutos",       jugadores_slots[minutos_jugados],
			        "partidos",      jugadores_slots[partidos_jugados],
			        "titularidades", jugadores_slots[titularidades],
			        "tarj_am",       jugadores_slots[tarjetas_amarillas],
			        "tarj_2am",      jugadores_slots[segunda_amarilla],
			        "tarj_roj",      jugadores_slots[tarjetas_rojas],
			        "entrada",       jugadores_slots[entrada_suplente],
			        "salida",        jugadores_slots[salida_suplente],
			        "min_gol",       jugadores_slots[min_por_gol],
			        "ppp",           jugadores_slots[ppp],
			        "pie",           jugadores_slots[pie],
			        "equipo",        jugadores_slots[alias_equipo],
			        "id_equipo",     jugadores_slots[id_equipo],
			        "goles_contra",  jugadores_slots[goles_en_contra],
			        "p_imbatido",    jugadores_slots[partidos_imbatido]
			    )
			
			VAR UniqueSlots = DISTINCT(SELECTCOLUMNS(Tabla, "s", [slot]))
			
			VAR BestXI =
			    GENERATE(
			        UniqueSlots,
			        VAR thisSlot = [s]
			        VAR filtered = FILTER(Tabla, [slot] = thisSlot)
			        RETURN ADDCOLUMNS(
			            TOPN(1, filtered, [score], DESC),
			            "cands", COUNTROWS(filtered)
			        )
			    )
			
			VAR Cards =
			    CONCATENATEX(
			        BestXI,
			        VAR xp   = FORMAT([x_coord], "0") & "%"
			        VAR yp   = FORMAT([y_coord], "0") & "%"
			        VAR nm   = LEFT([jugador], 18)
			        VAR sc   = FORMAT([score], "0.0")
			        VAR pos  = [posicion_xi]
			        VAR pie  = IF(ISBLANK([pie]), "", " | " & [pie])
			        VAR eq   = UPPER(IF(ISBLANK([equipo]), "", [equipo]))
			        VAR nc   = FORMAT([cands], "0")
			        VAR logo = LOOKUPVALUE(dm_equipos[url_logo], dm_equipos[id_equipo], [id_equipo])
			        VAR col  =
			            IF(pos = "POR", "#F1C40F",
			            IF(pos = "DFC" || pos = "LD" || pos = "LI", "#3498DB",
			            IF(pos = "MC"  || pos = "MCD" || pos = "MCO", "#2ECC71",
			            "#E74C3C")))
			
			        -- ── Pesos rendimiento ────────────────────────────────────────────
			        VAR wg   = IF(pos="DC",8,   IF(pos="EI"||pos="ED",6,   IF(pos="MCO",5,  IF(pos="MC",3,  IF(pos="MCD",2, 0)))))
			        VAR wa   = IF(pos="DC",3,   IF(pos="EI"||pos="ED",5,   IF(pos="MCO",6,  IF(pos="MC",4,  IF(pos="MCD",3, IF(pos="LD"||pos="LI",2, 0))))))
			        VAR dm   = IF(pos="POR",70, IF(pos="DFC",80, IF(pos="LD"||pos="LI",90, 100)))
			        VAR wp   = IF(pos="DC"||pos="EI"||pos="ED", 0.5, 0.3)
			        VAR wt   = 1.5
			
			        -- ── Pesos tarjetas / sustituciones ───────────────────────────────
			        VAR wam  = IF(pos="DC"||pos="EI"||pos="ED", 1,
			                   IF(pos="MCO"||pos="MC"||pos="LD"||pos="LI", 1.5, 2))
			        VAR wppp = IF(pos="DC"||pos="EI"||pos="ED", 2,
			                   IF(pos="MCO"||pos="MC"||pos="MCD", 1.5, 1))
			        VAR wsal = 0.5
			        VAR went = 0.3
			
			        -- ── Contribuciones específicas portero ────────────────────────────
			        VAR cgec = IF(pos="POR", [goles_contra] * 0.5, 0)   -- magnitud (penalización)
			        VAR cpib = IF(pos="POR", [p_imbatido]   * 2,   0)   -- bonificación
			
			        -- ── Escalones eficiencia (min_por_gol) ───────────────────────────
			        VAR eff_top = IF(pos="DC",10, IF(pos="EI"||pos="ED",8, IF(pos="MCO",5, IF(pos="MC",3, 0))))
			        VAR eff_mid = IF(pos="DC",6,  IF(pos="EI"||pos="ED",5, IF(pos="MCO",3, IF(pos="MC",2, 0))))
			        VAR eff_low = IF(pos="DC",3,  IF(pos="EI"||pos="ED",2, IF(pos="MCO",1, IF(pos="MC",1, 0))))
			        VAR ceff    = IF([min_gol] > 0   && [min_gol] <= 90,  eff_top,
			                     IF([min_gol] > 90  && [min_gol] <= 130, eff_mid,
			                     IF([min_gol] > 130 && [min_gol] <= 180, eff_low, 0)))
			
			        -- ── Contribuciones positivas ─────────────────────────────────────
			        VAR cg   = [goles]         * wg
			        VAR ca   = [asistencias]   * wa
			        VAR cm   = [minutos]       / dm
			        VAR cp   = [partidos]      * wp
			        VAR ct   = [titularidades] * wt
			        VAR cppp = [ppp]           * wppp
			
			        -- ── Penalizaciones (cgec incluida para POR) ───────────────────────
			        VAR cam  = [tarj_am]  * wam
			        VAR csal = [salida]   * wsal
			        VAR cent = [entrada]  * went
			        VAR pen  = [tarj_2am] * 3 + [tarj_roj] * 5 + cam + csal + cent + cgec
			
			        -- ── Totales para barras de % (cpib incluido para POR) ────────────
			        VAR tp   = cg + ca + cm + cp + ct + cppp + ceff + cpib
			        VAR tp2  = IF(tp > 0, tp, 1)
			        VAR pg   = FORMAT(IF(cg/tp2*100<100,   cg/tp2*100,   100), "0")
			        VAR pa   = FORMAT(IF(ca/tp2*100<100,   ca/tp2*100,   100), "0")
			        VAR pm   = FORMAT(IF(cm/tp2*100<100,   cm/tp2*100,   100), "0")
			        VAR pp   = FORMAT(IF(cp/tp2*100<100,   cp/tp2*100,   100), "0")
			        VAR pt   = FORMAT(IF(ct/tp2*100<100,   ct/tp2*100,   100), "0")
			        VAR pppp = FORMAT(IF(cppp/tp2*100<100, cppp/tp2*100, 100), "0")
			        VAR peff = FORMAT(IF(ceff/tp2*100<100, ceff/tp2*100, 100), "0")
			        VAR ppib = FORMAT(IF(cpib/tp2*100<100, cpib/tp2*100, 100), "0")
			
			        -- ── Score máx referencia por posición ────────────────────────────
			        VAR rm  = IF(pos="DC",290, IF(pos="EI"||pos="ED",240, IF(pos="MCO"||pos="MC",185, IF(pos="MCD",130, IF(pos="POR",100, 80)))))
			        VAR po  = FORMAT(IF([score]/rm*100<100, [score]/rm*100, 100), "0")
			
			        -- ── Valores display ───────────────────────────────────────────────
			        VAR zone = IF([y_coord] < 40, "top", IF([y_coord] >= 65, "bottom", "side"))
			        VAR tt_v = IF(zone = "side",   "top:-10px;bottom:auto",
			                IF(zone = "top",    "top:105%;bottom:auto",
			                                    "bottom:105%;top:auto"))
			        VAR tt_h = IF(zone = "side",
			                    IF([x_coord] <= 50, "left:calc(100% + 12px);right:auto;transform:none",
			                                        "right:calc(100% + 12px);left:auto;transform:none"),
			                IF([x_coord] < 30, "left:0;right:auto;transform:none",
			                IF([x_coord] > 68, "right:0;left:auto;transform:none",
			                                    "left:50%;transform:translateX(-50%)")))
			        VAR vg   = FORMAT([goles],         "0")
			        VAR va   = FORMAT([asistencias],   "0")
			        VAR vm   = FORMAT([minutos],       "0")
			        VAR vp   = FORMAT([partidos],      "0")
			        VAR vt   = FORMAT([titularidades], "0")
			        VAR vam  = FORMAT([tarj_am],       "0")
			        VAR vsal = FORMAT([salida],        "0")
			        VAR vent = FORMAT([entrada],       "0")
			        VAR vppp = FORMAT([ppp],           "0.00")
			        VAR vmg  = FORMAT([min_gol],       "0")
			        VAR vcg  = FORMAT(cg,   "0.1")
			        VAR vca  = FORMAT(ca,   "0.1")
			        VAR vcm  = FORMAT(cm,   "0.1")
			        VAR vcp  = FORMAT(cp,   "0.1")
			        VAR vct  = FORMAT(ct,   "0.1")
			        VAR vcppp= FORMAT(cppp, "0.1")
			        VAR vceff= FORMAT(ceff, "0.1")
			        VAR vpen = IF(pen > 0, "-" & FORMAT(pen, "0.1"), "0")
			        VAR vpib = FORMAT([p_imbatido],   "0")
			        VAR vgec = FORMAT([goles_contra], "0")
			        VAR vcpib = FORMAT(cpib, "0.1")
			        VAR vcgec = FORMAT(cgec, "0.1")
			        RETURN
			        "<div class='pc' style='position:absolute;left:" & xp & ";top:" & yp & ";transform:translate(-50%,-50%);text-align:center;z-index:10;min-width:70px;'>"
			        & "<div style='width:58px;height:58px;border-radius:50%;border:3px solid " & col & ";box-shadow:0 0 0 2px white,0 4px 14px rgba(0,0,0,0.9);overflow:hidden;margin:0 auto;'>"
			        & "<img src='" & [foto_url] & "' style='width:58px;height:58px;object-fit:cover;display:block;'/>"
			        & "</div>"
			        & "<div style='color:white;font-size:12px;font-weight:800;margin-top:3px;text-shadow:2px 2px 0 #000,-1px -1px 0 #000,1px -1px 0 #000,-1px 1px 0 #000;white-space:nowrap;'>" & nm & "</div>"
			        & "<div style='display:flex;align-items:center;justify-content:center;gap:4px;margin-top:1px;'>"
			        & IF(ISBLANK(logo),"","<img src='" & logo & "' style='width:14px;height:14px;object-fit:contain;'/>")
			        & "<span style='color:#FFE566;font-size:11px;font-weight:800;text-shadow:1px 1px 0 #000;letter-spacing:1px;'>" & eq & "</span>"
			        & "</div>"
			        & "<div style='display:flex;gap:3px;justify-content:center;margin-top:3px;'>"
			        & "<span style='background:" & col & ";color:white;font-size:10px;border-radius:4px;padding:2px 6px;font-weight:800;'>" & sc & "</span>"
			        & "<span style='background:rgba(0,0,0,0.85);color:#fff;font-size:10px;border-radius:4px;padding:2px 6px;font-weight:700;border:1px solid rgba(255,255,255,0.3);'>" & pos & pie & "</span>"
			        & "</div>"
			        & "<div class='tt' style='position:absolute;" & tt_v & ";" & tt_h & ";width:240px;background:rgba(8,15,25,0.97);border:1px solid rgba(255,255,255,0.25);border-radius:10px;padding:10px;z-index:200;text-align:left;box-shadow:0 8px 32px rgba(0,0,0,0.8);'>"
			        & "<div style='display:flex;align-items:center;gap:8px;margin-bottom:8px;border-bottom:1px solid rgba(255,255,255,0.15);padding-bottom:8px;'>"
			        & IF(ISBLANK(logo),"","<img src='" & logo & "' style='width:28px;height:28px;object-fit:contain;flex-shrink:0;'/>")
			        & "<div><div style='color:" & col & ";font-size:12px;font-weight:800;letter-spacing:1px;'>" & pos & "</div>"
			        & "<div style='color:white;font-size:13px;font-weight:700;'>" & [jugador] & "</div></div>"
			        & "</div>"
			        & "<div style='color:#aaa;font-size:11px;margin-bottom:4px;'>PUNTUACION TOTAL</div>"
			        & "<div style='background:rgba(255,255,255,0.1);border-radius:6px;height:10px;overflow:hidden;margin-bottom:4px;'>"
			        & "<div style='background:linear-gradient(90deg," & col & ",white);width:" & po & "%;height:100%;border-radius:6px;'></div>"
			        & "</div>"
			        & "<div style='display:flex;justify-content:space-between;color:white;font-size:13px;font-weight:800;margin-bottom:8px;'>"
			        & "<span>" & sc & " pts</span><span style='color:#aaa;font-size:9px;'>" & po & "% del máximo</span>"
			        & "</div>"
			        & "<div style='color:#aaa;font-size:11px;margin-bottom:6px;border-top:1px solid rgba(255,255,255,0.1);padding-top:6px;'>DESGLOSE</div>"
			        & IF(wg=0,"","<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Goles (" & vg & ")</span><span style='color:white;font-weight:700;'>+" & vcg & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#E74C3C;width:" & pg & "%;height:7px;border-radius:3px;'></div></div></div>")
			        & IF(wa=0,"","<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Asistencias (" & va & ")</span><span style='color:white;font-weight:700;'>+" & vca & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#3498DB;width:" & pa & "%;height:7px;border-radius:3px;'></div></div></div>")
			        & "<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Minutos (" & vm & ")</span><span style='color:white;font-weight:700;'>+" & vcm & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#2ECC71;width:" & pm & "%;height:7px;border-radius:3px;'></div></div></div>"
			        & "<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Partidos (" & vp & ")</span><span style='color:white;font-weight:700;'>+" & vcp & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#F1C40F;width:" & pp & "%;height:7px;border-radius:3px;'></div></div></div>"
			        & "<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Titularidades (" & vt & ")</span><span style='color:white;font-weight:700;'>+" & vct & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#9B59B6;width:" & pt & "%;height:7px;border-radius:3px;'></div></div></div>"
			        & "<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Rend. Equipo (PPP:" & vppp & ")</span><span style='color:white;font-weight:700;'>+" & vcppp & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#1ABC9C;width:" & pppp & "%;height:7px;border-radius:3px;'></div></div></div>"
			        & IF(ceff=0,"","<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Eficiencia (" & vmg & " min/gol)</span><span style='color:white;font-weight:700;'>+" & vceff & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#E67E22;width:" & peff & "%;height:7px;border-radius:3px;'></div></div></div>")
			        & IF(pos<>"POR","",
			            "<div style='margin-bottom:4px;'><div style='display:flex;justify-content:space-between;color:#ccc;font-size:11px;margin-bottom:2px;'><span>Porterías imbatidas (" & vpib & ")</span><span style='color:white;font-weight:700;'>+" & vcpib & "</span></div><div style='background:rgba(255,255,255,0.1);border-radius:3px;height:7px;'><div style='background:#27AE60;width:" & ppib & "%;height:7px;border-radius:3px;'></div></div></div>"
			            & "<div style='display:flex;justify-content:space-between;color:#E74C3C;font-size:11px;margin-bottom:4px;padding:4px 0;border-top:1px solid rgba(255,0,0,0.2);'><span>Goles en contra (" & vgec & ")</span><span style='font-weight:700;'>-" & vcgec & "</span></div>"
			        )
			        & "<div style='color:#ccc;font-size:11px;border-top:1px solid rgba(255,255,255,0.1);padding-top:6px;margin-top:4px;text-align:center;'>Elegido entre <span style='color:" & col & ";font-weight:800;'>" & nc & "</span> candidatos</div>"
			        & "</div>"
			        & "</div>",
			        ""
			    )
			
			RETURN
			"<style>html,body{margin:0;padding:0;overflow:visible;width:100%;height:100%;background:transparent;}.tt{display:none;}.pc:hover{z-index:500!important;}div:hover>.tt{display:block!important;}</style>"
			& "<div style='position:fixed;top:0;left:0;width:100%;height:100%;overflow:visible;font-family:Arial,sans-serif;background:transparent;'>"
			& Cards
			& "</div>"
		lineageTag: 22bf1c1a-3a89-40c8-8ab0-77d75a623c23

	column dummy
		dataType: int64
		isHidden
		lineageTag: 0a47c84b-99b0-4a40-820b-9a1c97eb1c05
		summarizeBy: none
		sourceColumn: [dummy]

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	partition Tabla_Medidas = calculated
		mode: import
		source = ROW("dummy", 0)

	annotation PBI_ResultType = Table

