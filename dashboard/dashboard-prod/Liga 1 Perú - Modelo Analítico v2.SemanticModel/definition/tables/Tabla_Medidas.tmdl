		dataCategory: ImageUrl

	measure 'Victorias Local' =
			
			CALCULATE(
			    DISTINCTCOUNT(ft_partidos_equipo[id_partido]),
			    ft_partidos_equipo[rol_equipo] = "LOCAL",
			    ft_partidos_equipo[resultado] = "G"
