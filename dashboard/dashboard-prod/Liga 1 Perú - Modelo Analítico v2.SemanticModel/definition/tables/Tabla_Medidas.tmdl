	measure 'Mayor Goleada' =
			
			VAR PartidoTop =
			    TOPN(
			        1,
			        FILTER(
			            ft_partidos_equipo,
			            ft_partidos_equipo[rol_equipo] = "LOCAL"
			        ),
			        ABS(ft_partidos_equipo[diferencia_goles]), DESC,
			        ft_partidos_equipo[goles_favor], DESC,
			        ft_partidos_equipo[fecha_partido], DESC
			    )
			RETURN
			CONCATENATEX(
			    PartidoTop,
			    UPPER(ft_partidos_equipo[alias_equipo])
			        & " ("
			        & ft_partidos_equipo[goles_favor]
			        & "-"
			        & ft_partidos_equipo[goles_contra]
			        & ") "
			        & UPPER(
			            LOOKUPVALUE(
			                dm_equipos[alias_equipo],
			                dm_equipos[id_equipo],
			                ft_partidos_equipo[id_rival]
			            )
			        ),
			    ""
			)
		lineageTag: c3d4e5f6-3333-4444-5555-666677778888

