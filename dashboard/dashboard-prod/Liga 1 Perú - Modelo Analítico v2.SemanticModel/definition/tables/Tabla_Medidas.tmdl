	/// Total de jugadores registrados en la plantilla según filtros activos
	measure 'Total Jugadores' =
			
			DISTINCTCOUNT(
			    ft_plantillas_historico[id_jugador]
			)
		formatString: 0
		lineageTag: a1b2c3d4-0001-0001-0001-000000000001

	/// Edad promedio del plantel (excluye filas sin edad)
	measure 'Edad Promedio' =
			
			AVERAGE(ft_plantillas_historico[edad_historica])
		formatString: 0.0
		lineageTag: a1b2c3d4-0001-0001-0001-000000000002

	/// Jugadores cuya nacionalidad principal no es peruana
	measure 'Total Extranjeros' =
			
			CALCULATE(
			    COUNTROWS(ft_plantillas_historico),
			    NOT(ft_plantillas_historico[nacionalidad_principal] IN {"Perú", "Peru", "Peruana"})
			)
		formatString: 0
		lineageTag: a1b2c3d4-0001-0001-0001-000000000003

	/// Valor total del plantel en millones de soles (PEN), usando tipo de cambio de _Parametros
	measure 'Valor Total Plantel EUR MM' =
			
			DIVIDE(
			    SUM(ft_plantillas_historico[valor_mercado]) * SELECTEDVALUE(_Parametros[TipoCambio]),
			    1000000
			)
		formatString: """S/ ""#,##0.0"" M"""
		lineageTag: a1b2c3d4-0001-0001-0001-000000000004

	/// Nombre del jugador con mayor valor de mercado del plantel
	measure 'Jugador Más Valioso' =
			
			VAR TopJugador =
			    TOPN(
			        1,
			        ft_plantillas_historico,
			        ft_plantillas_historico[valor_mercado], DESC,
			        ft_plantillas_historico[edad_historica], ASC,
			        ft_plantillas_historico[jugador], ASC
			    )
			RETURN
			CONCATENATEX(
			    TopJugador, ft_plantillas_historico[jugador]
			)
		lineageTag: c1c2c3c4-0003-0003-0003-000000000001

	/// Jugador más viejo del plantel con su edad
	measure 'Jugador Veterano' =
			
			VAR EdadMax =
			    MAX(ft_plantillas_historico[edad_historica])
			
			VAR TopJugador =
			    TOPN(
			        1,
			        FILTER(
			            ft_plantillas_historico,
			            ft_plantillas_historico[edad_historica] = EdadMax
			        ),
			        ft_plantillas_historico[valor_mercado], DESC,
			        ft_plantillas_historico[jugador], ASC
			    )
			
			RETURN
			CONCATENATEX(
			    TopJugador,
			        ft_plantillas_historico[jugador]
			        & " ("
			        & ft_plantillas_historico[edad_historica]
			        & " años)"
			)
		lineageTag: c1c2c3c4-0003-0003-0003-000000000002

	/// Jugador más joven del plantel con su edad
	measure 'Jugador Joven' =
			
			VAR EdadMin =
			    MIN(ft_plantillas_historico[edad_historica])
			
			VAR TopJugador =
			    TOPN(
			        1,
			        FILTER(
			            ft_plantillas_historico,
			            ft_plantillas_historico[edad_historica] = EdadMin
			        ),
			        ft_plantillas_historico[valor_mercado], DESC,
			        ft_plantillas_historico[jugador], ASC
			    )
			
			RETURN
			CONCATENATEX(
			    TopJugador,
			        ft_plantillas_historico[jugador]
			        & " ("
			        & ft_plantillas_historico[edad_historica]
			        & " años)"
			)
		lineageTag: c1c2c3c4-0003-0003-0003-000000000003

