		formatString: 0.0\ %;-0.0\ %;0.0\ %
		lineageTag: pa001001-0001-0001-0001-000000000010

		annotation PBI_FormatHint = {"isGeneralNumber":false}

	measure 'Logo Local' =
			
			VAR pid = [Partido Seleccionado Id]
			VAR idLocal =
			    CALCULATE(
			        MAX(ft_partidos_equipo[id_equipo]),
			        FILTER(
			            ALL(ft_partidos_equipo),
			            ft_partidos_equipo[id_partido] = pid
			                && ft_partidos_equipo[rol_equipo] = "LOCAL"
			        )
			    )
			RETURN
			LOOKUPVALUE(
			    dm_equipos[url_logo],
			    dm_equipos[id_equipo],
			    idLocal
			)
