		lineageTag: 0691b51b-27d6-4e25-8645-80247a14d734

	measure 'Fuera de Porteria' =
			
			SUM(ft_partidos_equipo[tiros_totales]) - SUM(ft_partidos_equipo[disparos_puerta])
		formatString: 0
		lineageTag: 921085fb-7f5a-437b-a752-9a6f662a54dc

	measure 'Precision Porteria' =
			
			DIVIDE(
			    SUM(ft_partidos_equipo[disparos_puerta]),
			    SUM(ft_partidos_equipo[tiros_totales])
			)
		lineageTag: f6d91acb-3a46-4e76-abf4-cc67e315811d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Precision Tiro Fuera' =
			
