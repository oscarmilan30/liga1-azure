table Tabla_Medidas
	lineageTag: 7ecd2786-b825-43f9-9a03-99512b9e5c87

	measure 'Valor Promedio Jugador PEN' = ```
			
			/*
			Convierte el valor medio de mercado de EUR a PEN
			AVERAGE: promedio según filtro activo (temporada, equipo, etc.)
			SELECTEDVALUE: lee el tipo de cambio desde _Parametros (tabla de 1 sola fila)
			*/
			AVERAGE(ft_evolucion_valoracion[valor_medio])  * SELECTEDVALUE(_Parametros[TipoCambio])
			
			```
		formatString: "S/ "#,##0.00
		lineageTag: c33470db-c3e8-4722-ae0f-980890b78409

		annotation PBI_FormatHint = {"isGeneralNumber":false}

	measure 'Valor Total Plantel PEN' =
			
			/* Suma total del valor del plantel convertido de EUR a PEN
			   SUM: total según filtro activo
			   SELECTEDVALUE: tipo de cambio centralizado en _Parametros*/
			SUM(ft_evolucion_valoracion[valor_total])  * SELECTEDVALUE(_Parametros[TipoCambio])
		formatString: "S/ "#,##0.00
		lineageTag: 08a95322-8eb3-4e52-8dbd-8e5839fe24ae

		annotation PBI_FormatHint = {"isGeneralNumber":false}

	measure 'Valor Total Plantel MM PEN' = ```
			
			   /*Valor total de plantillas de la última temporada en millones de PEN
			     Filtra siempre la temporada más reciente ignorando filtros externos
			     DIVIDE: retorna BLANK si denominador es 0*/
			VAR ultimaTemp =
			    CALCULATE(MAX(ft_evolucion_valoracion[temporada]), ALL(ft_evolucion_valoracion))
			RETURN
			
			    CALCULATE(
			        SUM(ft_evolucion_valoracion[valor_total]),
			        ft_evolucion_valoracion[temporada] = ultimaTemp
			    ) * SELECTEDVALUE(_Parametros[TipoCambio])
			
			```
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: 421ab290-4d1e-46d0-9aa5-cccb889bd591

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

