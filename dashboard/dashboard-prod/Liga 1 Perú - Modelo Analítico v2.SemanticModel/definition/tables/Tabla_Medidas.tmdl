		formatString: 0
		lineageTag: b1b2c3d4-0002-0002-0002-000000000002

	/// Promedio de partidos dirigidos por DT
	measure 'Promedio de Partidos por DT' =
			
			AVERAGEX(
			    FILTER(ft_entrenadores_historico, ft_entrenadores_historico[partidos] >= 10),
			    ft_entrenadores_historico[partidos]
			)
		formatString: 0.0
		lineageTag: b1b2c3d4-0002-0002-0002-000000000003

	/// Entrenadores cuya nacionalidad no es peruana
	measure 'Entrenadores Extranjeros' =
			
			CALCULATE(
			    DISTINCTCOUNT(ft_entrenadores_historico[id_entrenador]),
			    NOT(ft_entrenadores_historico[nacionalidad_principal] IN {"Perú", "Peru", "Peruana"})
			)
		formatString: 0
		lineageTag: b1b2c3d4-0002-0002-0002-000000000004

	/// Valor de mercado individual del jugador en soles (para tabla Plantillas)
	measure 'Valor Mercado PEN' =
			
			SUM(ft_plantillas_historico[valor_mercado]) * SELECTEDVALUE(_Parametros[TipoCambio])
		lineageTag: 381595a2-ce6f-4637-9d08-159873c959c5

	/// Valor total de la liga en millones de PEN (respeta filtros activos de temporada/equipo)
	measure 'Valor Total Liga Val MM' = ```
			
			
			    SUM(ft_evolucion_valoracion[valor_total]) * SELECTEDVALUE(_Parametros[TipoCambio])
			
			```
		formatString: "S/"\ #,0.00;-"S/"\ #,0.00;"S/"\ #,0.00
		lineageTag: aa010001-0001-0001-0001-000000000001

		annotation PBI_FormatHint = {"currencyCulture":"es-PE"}

	/// Nombre del equipo con mayor valor total de mercado (respeta filtros)
	measure 'Equipo Más Valioso Val' =
			
			VAR resumen =
			    SUMMARIZE(
			        ft_evolucion_valoracion,
			        ft_evolucion_valoracion[nombre_equipo],
			        "VT", SUM(ft_evolucion_valoracion[valor_total])
			    )
			VAR top1 = TOPN(1, resumen, [VT], DESC)
			RETURN CONCATENATEX(top1, ft_evolucion_valoracion[nombre_equipo])
		lineageTag: aa010001-0001-0001-0001-000000000002

	/// Valor del equipo más valioso en millones de PEN
	measure 'Valor Equipo Top MM' =
			
			VAR resumen =
			    SUMMARIZE(
			        ft_evolucion_valoracion,
			        ft_evolucion_valoracion[nombre_equipo],
			        "VT", SUM(ft_evolucion_valoracion[valor_total])
			    )
			RETURN
			DIVIDE(
			    MAXX(resumen, [VT]) * SELECTEDVALUE(_Parametros[TipoCambio]),
			    1000000
			)
		formatString: \"S/ \"#,##0.0\" MM\"
		lineageTag: aa010001-0001-0001-0001-000000000003

	/// Edad promedio de la liga (ft_evolucion_valoracion, respeta filtros)
	measure 'Edad Promedio Liga Val' =
			
			AVERAGE(ft_evolucion_valoracion[edad_promedio])
		formatString: 0.0
		lineageTag: aa010001-0001-0001-0001-000000000004

	/// Promedio de jugadores extranjeros por equipo
	measure 'Extranjeros Promedio Equipo Val' =
			
			AVERAGE(ft_evolucion_valoracion[extranjeros])
		formatString: 0.0
		lineageTag: aa010001-0001-0001-0001-000000000005

	/// Crecimiento interanual del valor total de la liga (ultima temporada vs anterior)
	measure 'Crecimiento Valor Liga %' =
			
			VAR TempActual =
			    SELECTEDVALUE(ft_evolucion_valoracion[temporada])
			
			VAR TempAnterior =
			    TempActual - 1
			
			VAR ValorActual =
			    CALCULATE(
			        SUM(ft_evolucion_valoracion[valor_total]),
			        ft_evolucion_valoracion[temporada] = TempActual
			    )
			
			VAR ValorAnterior =
			    CALCULATE(
			        SUM(ft_evolucion_valoracion[valor_total]),
			        ft_evolucion_valoracion[temporada] = TempAnterior
			    )
			
			RETURN
			DIVIDE(
			    ValorActual - ValorAnterior,
			    ValorAnterior
			)
		formatString: +0.0%;-0.0%;0.0%
		lineageTag: aa010001-0001-0001-0001-000000000006

	/// Promedio de jugadores por plantel (ft_evolucion_valoracion)
	measure 'Jugadores Promedio Plantel Val' =
			
			AVERAGE(ft_evolucion_valoracion[jugadores_en_plantilla])
		formatString: 0.0
		lineageTag: aa010001-0001-0001-0001-000000000007

	/// % del valor total de la liga concentrado en los 3 equipos mas valiosos
	measure 'Concentracion Top 3 Valor' =
			
			VAR resumen =
			    SUMMARIZE(
			        ft_evolucion_valoracion,
			        ft_evolucion_valoracion[nombre_equipo],
			        "VT", SUM(ft_evolucion_valoracion[valor_total])
			    )
			VAR top3 = SUMX(TOPN(3, resumen, [VT], DESC), [VT])
			VAR total  = SUMX(resumen, [VT])
			RETURN DIVIDE(top3, total)
		formatString: 0.0%
		lineageTag: aa010001-0001-0001-0001-000000000008

	/// Puntos acumulados por equipo para correlacion valor/rendimiento (scatter)
	measure 'Puntos Acumulado Val' =
			
			CALCULATE(
			    SUM(ft_rendimiento_posiciones[puntos]),
			    ALL(dm_tipo_tabla)
			)
		formatString: 0
		lineageTag: aa010001-0001-0001-0001-000000000009

	measure 'Mejor DT' =
			
			VAR TopDT =
			    TOPN(
			        1,
			        FILTER(
			            ft_entrenadores_historico,
			            ft_entrenadores_historico[partidos] >= 10 &&
			            ft_entrenadores_historico[ppp] > 0
			        ),
			        ft_entrenadores_historico[ppp], DESC,
			        ft_entrenadores_historico[partidos], DESC,
			        ft_entrenadores_historico[entrenador], ASC
			    )
			RETURN
			CONCATENATEX(TopDT, ft_entrenadores_historico[entrenador])
		lineageTag: c39f2cd7-661b-45d4-9825-ea0c5454bccd

	measure 'DT Más Partidos' =
			
			VAR TopDT =
			    TOPN(
			        1,
			        ft_entrenadores_historico,
			        ft_entrenadores_historico[partidos],
			        DESC
			    )
			RETURN
			CONCATENATEX(
			    TopDT,
			    ft_entrenadores_historico[entrenador]
			)
		lineageTag: d28f3d4a-2dc5-4756-9cea-24503c20e3d7

	measure 'DT Activo' =
			
			CONCATENATEX(
