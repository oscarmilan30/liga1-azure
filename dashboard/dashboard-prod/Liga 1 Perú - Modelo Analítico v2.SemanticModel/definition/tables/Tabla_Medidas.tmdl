	measure 'Puntos Equipo Temporada Val' =
			
			VAR TempSel = SELECTEDVALUE(ft_evolucion_valoracion[temporada])
			RETURN
			CALCULATE(
			    SUM(ft_rendimiento_posiciones[puntos]),
