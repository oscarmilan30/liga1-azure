	/// Total de empates según filtros activos
	measure Empates =
			
			CALCULATE(
			    COUNTROWS(ft_partidos_equipo),
			    ft_partidos_equipo[resultado] = "E"
			)
		formatString: 0
		lineageTag: pa001001-0001-0001-0001-000000000006

	/// Total de derrotas según filtros activos
	measure Derrotas =
			
